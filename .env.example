# Deposium CLI - Configuration Environment Variables
# Copy this file to .env and fill in your values
# Priority: Environment variables > Config file (~/.deposium/config.json) > Defaults

# MCP Server URL (required)
DEPOSIUM_MCP_URL=http://localhost:4001

# API Key for authentication (required)
DEPOSIUM_API_KEY=your-api-key-here

# Default tenant ID (optional)
DEPOSIUM_TENANT=default

# Default space ID (optional)
DEPOSIUM_SPACE=default

# Output format: json | table | markdown (default: table)
DEPOSIUM_OUTPUT=table

# Silent mode: true | false (default: false)
DEPOSIUM_SILENT=false
