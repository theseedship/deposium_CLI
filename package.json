{
  "name": "@deposium/cli",
  "version": "1.0.1",
  "description": "CLI for Deposium MCP Server - Document search, graph queries, and AI workflows",
  "main": "dist/cli.js",
  "bin": {
    "deposium": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc",
    "build:bun": "bun build --compile --minify src/cli.ts --outfile dist/deposium",
    "build:all": "npm run build:bun-linux && npm run build:bun-macos && npm run build:bun-windows",
    "build:bun-linux": "bun build --compile --target=linux-x64 --minify src/cli.ts --outfile dist/deposium-linux",
    "build:bun-macos": "bun build --compile --target=darwin-x64 --minify src/cli.ts --outfile dist/deposium-macos",
    "build:bun-windows": "bun build --compile --target=windows-x64 --minify src/cli.ts --outfile dist/deposium-windows.exe",
    "start": "node dist/cli.js",
    "install:local": "npm run build && npm link",
    "uninstall:local": "npm unlink -g @deposium/cli",
    "pack:local": "npm run build && npm pack",
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'src/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' --fix",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist node_modules",
    "prepare": "husky || true"
  },
  "keywords": [
    "deposium",
    "mcp",
    "cli",
    "search",
    "graph",
    "ai",
    "rag",
    "duckdb"
  ],
  "author": "The Seed Ship",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/theseedship/deposium_CLI.git"
  },
  "homepage": "https://github.com/theseedship/deposium_CLI#readme",
  "bugs": {
    "url": "https://github.com/theseedship/deposium_CLI/issues"
  },
  "files": [
    "dist/",
    "LICENSE",
    "README.md",
    "SECURITY.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "conf": "^15.1.0",
    "dotenv": "^17.2.4",
    "glob": "^13.0.2",
    "gradient-string": "^3.0.0",
    "inquirer": "^13.2.2",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "mime-types": "^3.0.2",
    "ora": "^9.3.0"
  },
  "devDependencies": {
    "@types/mime-types": "^3.0.1",
    "@types/node": "^22.19.11",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=22",
    "bun": ">=1.0.0"
  },
  "overrides": {
    "minimatch": ">=10.2.4",
    "rollup": ">=4.59.0"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
