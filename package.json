{
  "name": "@deposium/cli",
  "version": "1.0.0",
  "description": "CLI for Deposium MCP Server - Document search, graph queries, and AI workflows",
  "main": "dist/cli.js",
  "bin": {
    "deposium": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc",
    "build:bun": "bun build --compile --minify src/cli.ts --outfile dist/deposium",
    "build:all": "npm run build:bun-linux && npm run build:bun-macos && npm run build:bun-windows",
    "build:bun-linux": "bun build --compile --target=linux-x64 --minify src/cli.ts --outfile dist/deposium-linux",
    "build:bun-macos": "bun build --compile --target=darwin-x64 --minify src/cli.ts --outfile dist/deposium-macos",
    "build:bun-windows": "bun build --compile --target=windows-x64 --minify src/cli.ts --outfile dist/deposium-windows.exe",
    "start": "node dist/cli.js",
    "install:local": "npm run build && npm link",
    "uninstall:local": "npm unlink -g @deposium/cli",
    "pack:local": "npm run build && npm pack",
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'src/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' --fix",
    "format": "prettier --write .",
    "test": "bun test",
    "clean": "rm -rf dist node_modules",
    "prepare": "husky || true"
  },
  "keywords": [
    "deposium",
    "mcp",
    "cli",
    "search",
    "graph",
    "ai",
    "rag",
    "duckdb"
  ],
  "author": "The Seed Ship",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/theseedship/deposium_CLI.git"
  },
  "dependencies": {
    "ascii-tree": "^0.3.0",
    "axios": "^1.13.2",
    "glob": "^11.0.0",
    "mime-types": "^2.1.35",
    "boxen": "^8.0.1",
    "chalk": "^5.3.0",
    "cli-progress": "^3.12.0",
    "cli-spinners": "^3.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.2",
    "conf": "^13.1.0",
    "dotenv": "^17.2.3",
    "gradient-string": "^3.0.0",
    "inquirer": "^12.11.0",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "ora": "^9.0.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.6",
    "@types/inquirer": "^9.0.7",
    "@types/mime-types": "^2.1.4",
    "@types/node": "^22.17.2",
    "@typescript-eslint/eslint-plugin": "^8.40.0",
    "@typescript-eslint/parser": "^8.40.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6",
    "prettier": "^3.6.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20",
    "bun": ">=1.0.0"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
